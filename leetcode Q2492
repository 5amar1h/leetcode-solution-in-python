class Solution(object):
    def minScore(self, n, roads):
        """
        :type n: int
        :type roads: List[List[int]]
        :rtype: int
        """
        graph = {}
        for i in xrange(1, n + 1):
            graph[i] = []

        for a, b, d in roads:
            graph[a].append((b, d))
            graph[b].append((a, d))

        visited = set()
        stack = [1]
        ans = float('inf')

        while stack:
            node = stack.pop()
            if node in visited:
                continue
            visited.add(node)

            for nei, dist in graph[node]:
                ans = min(ans, dist)
                if nei not in visited:
                    stack.append(nei)

        return ans
