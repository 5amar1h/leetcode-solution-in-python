class Solution(object):
    def uniqueXorTriplets(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        MAXX = 2048

        dp = [[False] * MAXX for _ in xrange(4)]
        dp[0][0] = True

        for v in nums:
            for cnt in xrange(2, -1, -1):
                cur = dp[cnt]
                nxt = dp[cnt + 1]
                for x in xrange(MAXX):
                    if cur[x]:
                        nxt[x ^ v] = True

        seen = [False] * MAXX

        # Triplets with repeated indices -> original values
        for v in nums:
            seen[v] = True

        # Triplets with 3 distinct indices
        for x in xrange(MAXX):
            if dp[3][x]:
                seen[x] = True

        ans = 0
        for v in seen:
            if v:
                ans += 1
        return ans
